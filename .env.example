# ----------------------------------------------------------------------------
# Expense Tracker — environment template
# Copy values into the appropriate locations; do NOT commit the filled file.
# ----------------------------------------------------------------------------

# === Frontend (expense-tracker/src/environments/environment.ts) =============
# Found in Supabase dashboard > Project Settings > API.
SUPABASE_URL=https://xpriirncttaszmnxftbm.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...

# === Edge Function secrets (set via `supabase secrets set ...`) =============
# NOTE: SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY are
# AUTO-INJECTED into every Edge Function by Supabase. You cannot set them
# manually — the CLI rejects any name starting with SUPABASE_. They're listed
# above only because the frontend also needs the URL + anon key.
#
# The only secret you actually set yourself is the Gemini key:
# Free Gemini key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# === Local Supabase CLI (used by supabase config.toml during `supabase start`)
# Get these by creating an OAuth 2.0 Web Client in Google Cloud Console
# and enabling the Gmail API on the same project.
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
